# Copy to /etc/seltra/orderbook-api.env on the server, set root:seltra mode 640, and replace placeholders.

PORT=8080
CHAIN_ID=43113
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Required on Avalanche mainnet. Use the managed database's private hostname,
# verify its CA, and keep this secret only in the server-side .env file.
DATABASE_URL="postgresql://seltra_app:REPLACE@private-REPLACE:25060/seltra_staging?sslmode=verify-full&sslrootcert=/etc/seltra/do-postgres-ca.crt"

SETTLEMENT=0x962F86c218eEdEbFd2AAc6cb35b5283232769848
ROUTER=0xba1f5399D6A09b73206EC9449e2ba1bA7db27257

BASE_TOKEN=0x760D9a5B4ae94f5e6c3ce014e3C116544515C830
BASE_SYMBOL=sWAVAX
BASE_DECIMALS=18
QUOTE_TOKEN=0x00B766567013BbCe12bF802f6E7C65F6da581Efe
QUOTE_SYMBOL=sUSDC
QUOTE_DECIMALS=6

# "adapterId:Name" comma-separated; mainnet becomes e.g. "1:LFJ,2:Blackhole,3:Pharaoh"
VENUES=0:Demo DEX
START_BLOCK=57057712
CONFIRMATIONS=2

# Production tightening (defaults are dev-friendly):
CORS_ORIGIN=https://app.YOURDOMAIN
RATE_SUBMIT_PER_MIN=20
RATE_REQUESTS_PER_MIN=600
