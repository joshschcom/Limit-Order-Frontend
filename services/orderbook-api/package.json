{
  "name": "@seltra/orderbook-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/*.test.ts",
    "db:migrate": "tsx scripts/migrate-sqlite-to-postgres.ts",
    "db:verify": "tsx scripts/migrate-sqlite-to-postgres.ts --verify-only",
    "db:rewind": "tsx scripts/rewind-postgres-checkpoint.ts"
  },
  "dependencies": {
    "@seltra/sdk": "*",
    "pg": "^8.22.0",
    "viem": "^2.18.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.12",
    "pg-mem": "^3.0.14",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3"
  }
}
